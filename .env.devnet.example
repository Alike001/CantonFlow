# CantonFlow DevNet deployment configuration.
# Copy to .env.devnet and fill values from your validator/Keycloak setup.

# JSON Ledger API exposed by your DevNet validator.
# Linux docs commonly use http://json-ledger-api.localhost:${LEDGER_PORT}
# MacOS docs commonly use http://json-ledger-api.localhost:8080
JSON_LEDGER_API_URL=http://json-ledger-api.localhost:8080

# OAuth2 token with package upload/admin rights.
# Do not commit real tokens.
LEDGER_API_TOKEN=

# Local sandbox only. Keep false/empty for DevNet.
CANTONFLOW_ALLOW_UNAUTHENTICATED_JSON_API=false

# CantonFlow package ID from:
# HOME=$PWD/.home .tools/dpm/dpm damlc inspect-dar .daml/dist/cantonflow-0.1.0.dar
CANTONFLOW_PACKAGE_ID=
CANTONFLOW_APPLICATION_ID=cantonflow

# Optional role-specific users. If omitted, the app falls back to
# CANTONFLOW_USER_ID, then to the configured role name.
CANTONFLOW_USER_ID=
CANTONFLOW_SUPPLIER_USER_ID=
CANTONFLOW_BUYER_USER_ID=
CANTONFLOW_REGULATOR_USER_ID=
CANTONFLOW_LENDER_A_USER_ID=
CANTONFLOW_LENDER_B_USER_ID=

# DevNet party IDs. Use the full party strings returned by /v2/parties.
CANTONFLOW_SUPPLIER_PARTY=
CANTONFLOW_BUYER_PARTY=
CANTONFLOW_REGULATOR_PARTY=
CANTONFLOW_LENDER_A_PARTY=
CANTONFLOW_LENDER_B_PARTY=

# DAR path produced by dpm build / daml build.
DAR_PATH=.daml/dist/cantonflow-0.1.0.dar

# Optional: force package vetting on upload.
VET_ALL_PACKAGES=true
