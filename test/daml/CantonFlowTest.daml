module CantonFlowTest where

import CantonFlow
import Daml.Script
import DA.Date
import DA.Time

testReceivablesRfqLifecycle : Script ()
testReceivablesRfqLifecycle = script do
  supplier <- allocatePartyByHint (PartyIdHint "supplier")
  buyer <- allocatePartyByHint (PartyIdHint "buyer")
  regulator <- allocatePartyByHint (PartyIdHint "regulator")
  lenderA <- allocatePartyByHint (PartyIdHint "lender-a")
  lenderB <- allocatePartyByHint (PartyIdHint "lender-b")

  let due = date 2026 Aug 30
  let submitted = time (date 2026 Jul 11) 9 0 0
  let invited = time (date 2026 Jul 11) 9 1 0
  let accepted = time (date 2026 Jul 11) 9 5 0
  let prepared = time (date 2026 Jul 11) 9 10 0
  let confirmed = time (date 2026 Jul 11) 9 15 0

  invoiceRequest <- submit supplier do
    createCmd InvoiceRequest with
      supplier
      buyer
      regulator
      invoiceId = "receivable-001"
      invoiceNumber = "INV-2026-004"
      buyerProfile = "Investment-grade manufacturing buyer"
      amount = 320000.0
      currency = "USD"
      dueDate = due
      requestedAdvance = 252000.0
      maximumDiscountRate = 4.5

  submitMustFail buyer do
    exerciseCmd invoiceRequest OpenFundingRound

  fundingRound <- submit supplier do
    exerciseCmd invoiceRequest OpenFundingRound

  submitMustFail supplier do
    exerciseCmd invoiceRequest OpenFundingRound

  submit supplier do
    createCmd WorkflowAuditEvent with
      eventOwner = supplier
      supplier
      regulator
      invoiceId = "receivable-001"
      invoiceNumber = "INV-2026-004"
      stage = AuditInvoiceSubmitted
      occurredAt = submitted

  submitMustFail buyer do
    exerciseCmd fundingRound InviteLender with
      lender = lenderA
      occurredAt = invited

  fundingRoundAfterA <- submit supplier do
    exerciseCmd fundingRound InviteLender with
      lender = lenderA
      occurredAt = invited

  lenderAInvites <- query @LenderInvite lenderA
  lenderAInvite <- case lenderAInvites of
    [(contractId, _)] -> pure contractId
    _ -> abort "Expected one lender A invitation"

  submitMustFail supplier do
    exerciseCmd fundingRoundAfterA InviteLender with
      lender = lenderA
      occurredAt = invited

  fundingRoundAfterB <- submit supplier do
    exerciseCmd fundingRoundAfterA InviteLender with
      lender = lenderB
      occurredAt = invited

  lenderBInvites <- query @LenderInvite lenderB
  lenderBInvite <- case lenderBInvites of
    [(contractId, _)] -> pure contractId
    _ -> abort "Expected one lender B invitation"

  submitMustFail lenderB do
    exerciseCmd lenderBInvite SubmitFundingBid with
      advanceAmount = 252001.0
      discountRate = 4.7
      settlementDays = 60
      lenderNote = "Invalid advance amount."
      submittedAt = submitted

  lenderABid <- submit lenderA do
    exerciseCmd lenderAInvite SubmitFundingBid with
      advanceAmount = 252000.0
      discountRate = 4.4
      settlementDays = 61
      lenderNote = "Can settle quickly after invoice verification."
      submittedAt = submitted

  submitMustFail lenderA do
    exerciseCmd lenderAInvite SubmitFundingBid with
      advanceAmount = 252000.0
      discountRate = 4.4
      settlementDays = 61
      lenderNote = "Repeated bid."
      submittedAt = submitted

  lenderBBid <- submit lenderB do
    exerciseCmd lenderBInvite SubmitFundingBid with
      advanceAmount = 248000.0
      discountRate = 4.2
      settlementDays = 60
      lenderNote = "Competing lender bid."
      submittedAt = submitted

  fundingAgreement <- submit supplier do
    exerciseCmd lenderABid AcceptBid with
      fundingRoundToClose = fundingRoundAfterB
      acceptedAt = accepted

  submitMustFail supplier do
    exerciseCmd lenderBBid AcceptBid with
      fundingRoundToClose = fundingRoundAfterB
      acceptedAt = accepted

  settlementProposal <- submit supplier do
    exerciseCmd fundingAgreement ProposeSettlement with
      settlementReference = "cantonflow-settlement-001"
      preparedAt = prepared

  submitMustFail lenderB do
    exerciseCmd settlementProposal ConfirmSettlement with
      confirmedAt = confirmed

  settlementInstruction <- submit lenderA do
    exerciseCmd settlementProposal ConfirmSettlement with
      confirmedAt = confirmed

  regulatorBids <- query @FundingBid regulator
  regulatorAgreements <- query @FundingAgreement regulator
  regulatorSettlementProposals <- query @SettlementProposal regulator
  regulatorSettlements <- query @SettlementInstruction regulator
  regulatorAuditEvents <- query @WorkflowAuditEvent regulator
  lenderABids <- query @FundingBid lenderA
  lenderBBids <- query @FundingBid lenderB

  assert (null regulatorBids)
  assert (null regulatorAgreements)
  assert (null regulatorSettlementProposals)
  assert (null regulatorSettlements)
  assert (length regulatorAuditEvents == 8)
  assert (length lenderABids == 0)
  assert (length lenderBBids == 1)
