module CantonFlowTest where

import CantonFlow
import Daml.Script
import DA.Date
import DA.Time

testReceivablesRfqLifecycle : Script ()
testReceivablesRfqLifecycle = script do
  supplier <- allocatePartyByHint (PartyIdHint "supplier")
  buyer <- allocatePartyByHint (PartyIdHint "buyer")
  regulator <- allocatePartyByHint (PartyIdHint "regulator")
  lender <- allocatePartyByHint (PartyIdHint "lender")

  let due = date 2026 Aug 30
  let submitted = time (date 2026 Jul 11) 9 0 0
  let invited = time (date 2026 Jul 11) 9 1 0
  let accepted = time (date 2026 Jul 11) 9 5 0
  let prepared = time (date 2026 Jul 11) 9 10 0
  let confirmed = time (date 2026 Jul 11) 9 15 0

  invoiceRequest <- submit supplier do
    createCmd InvoiceRequest with
      supplier
      buyer
      regulator
      invoiceId = "receivable-001"
      invoiceNumber = "INV-2026-004"
      buyerProfile = "Investment-grade manufacturing buyer"
      amount = 320000.0
      currency = "USD"
      dueDate = due
      requestedAdvance = 252000.0
      minimumDiscountRate = 4.5

  submit supplier do
    createCmd WorkflowAuditEvent with
      eventOwner = supplier
      supplier
      regulator
      invoiceId = "receivable-001"
      invoiceNumber = "INV-2026-004"
      stage = AuditInvoiceSubmitted
      occurredAt = submitted

  lenderInvite <- submit supplier do
    exerciseCmd invoiceRequest InviteLender with
      lender
      occurredAt = invited

  fundingBid <- submit lender do
    exerciseCmd lenderInvite SubmitFundingBid with
      advanceAmount = 252000.0
      discountRate = 4.9
      settlementDays = 61
      lenderNote = "Can settle quickly after invoice verification."
      submittedAt = submitted

  fundingAgreement <- submit supplier do
    exerciseCmd fundingBid AcceptBid with
      acceptedAt = accepted

  settlementProposal <- submit supplier do
    exerciseCmd fundingAgreement ProposeSettlement with
      settlementReference = "cantonflow-settlement-001"
      preparedAt = prepared

  settlementInstruction <- submit lender do
    exerciseCmd settlementProposal ConfirmSettlement with
      confirmedAt = confirmed

  regulatorBids <- query @FundingBid regulator
  regulatorAgreements <- query @FundingAgreement regulator
  regulatorSettlementProposals <- query @SettlementProposal regulator
  regulatorSettlements <- query @SettlementInstruction regulator
  regulatorAuditEvents <- query @WorkflowAuditEvent regulator

  assert (null regulatorBids)
  assert (null regulatorAgreements)
  assert (null regulatorSettlementProposals)
  assert (null regulatorSettlements)
  assert (length regulatorAuditEvents == 6)
